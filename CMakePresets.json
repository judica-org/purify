{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ci-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PURIFY_BUILD_BENCH": "OFF",
        "PURIFY_BUILD_CLI": "ON",
        "PURIFY_BUILD_DOCS": "OFF",
        "PURIFY_BUILD_FUZZ": "OFF",
        "PURIFY_BUILD_REFERENCE_TESTS": "ON",
        "PURIFY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tagged",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-tagged",
      "cacheVariables": {
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    },
    {
      "name": "legacy",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-legacy",
      "cacheVariables": {
        "PURIFY_USE_LEGACY_FIELD_HASHES": "ON"
      }
    },
    {
      "name": "sanitizers",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-sanitizers",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PURIFY_BUILD_REFERENCE_TESTS": "OFF",
        "PURIFY_ENABLE_SANITIZERS": "ON",
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    },
    {
      "name": "sanitizers-int",
      "inherits": "sanitizers",
      "binaryDir": "${sourceDir}/build-sanitizers-int",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "PURIFY_SANITIZER_LIST": "address,undefined,integer"
      }
    },
    {
      "name": "trapv-i686",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-trapv-i686",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_FLAGS": "-m32 -ftrapv -Werror=pedantic",
        "CMAKE_CXX_FLAGS": "-m32 -ftrapv -Werror=pedantic",
        "CMAKE_EXE_LINKER_FLAGS": "-m32 -ftrapv",
        "CMAKE_SHARED_LINKER_FLAGS": "-m32 -ftrapv",
        "PURIFY_BUILD_CLI": "OFF",
        "PURIFY_BUILD_REFERENCE_TESTS": "OFF",
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    },
    {
      "name": "bitcoin-i686-debug",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-bitcoin-i686-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_FLAGS": "-m32 -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -Wstack-protector -fstack-protector-all -fcf-protection=full -fstack-clash-protection",
        "CMAKE_CXX_FLAGS": "-m32 -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -Wstack-protector -fstack-protector-all -fcf-protection=full -fstack-clash-protection -D_GLIBCXX_DEBUG -D_GLIBCXX_DEBUG_PEDANTIC -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_DEBUG -DBOOST_MULTI_INDEX_ENABLE_SAFE_MODE",
        "CMAKE_C_FLAGS_DEBUG": "-O0 -ftrapv -O1 -g3 -g3",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0 -ftrapv -O1 -g3 -g3",
        "CMAKE_EXE_LINKER_FLAGS": "-m32 -ftrapv -O1 -g3 -g3 -fstack-protector-all -fcf-protection=full -fstack-clash-protection -Wl,-z,relro -Wl,-z,now -Wl,-z,separate-code -fPIE -pie",
        "CMAKE_SHARED_LINKER_FLAGS": "-m32 -ftrapv -O1 -g3 -g3 -fstack-protector-all -fcf-protection=full -fstack-clash-protection -Wl,-z,relro -Wl,-z,now -Wl,-z,separate-code",
        "PURIFY_BUILD_BENCH": "ON",
        "PURIFY_BUILD_CLI": "OFF",
        "PURIFY_BUILD_FUZZ": "OFF",
        "PURIFY_BUILD_REFERENCE_TESTS": "OFF",
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    },
    {
      "name": "valgrind",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-valgrind",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "PURIFY_BUILD_BENCH": "OFF",
        "PURIFY_BUILD_CLI": "OFF",
        "PURIFY_BUILD_DOCS": "OFF",
        "PURIFY_BUILD_REFERENCE_TESTS": "OFF",
        "PURIFY_BUILD_VALGRIND_TESTS": "ON",
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    },
    {
      "name": "cbmc",
      "inherits": "ci-base",
      "binaryDir": "${sourceDir}/build-cbmc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PURIFY_BUILD_BENCH": "OFF",
        "PURIFY_BUILD_CBMC": "ON",
        "PURIFY_BUILD_CLI": "OFF",
        "PURIFY_BUILD_DOCS": "OFF",
        "PURIFY_BUILD_FUZZ": "OFF",
        "PURIFY_BUILD_REFERENCE_TESTS": "OFF",
        "PURIFY_BUILD_TESTS": "OFF",
        "PURIFY_USE_LEGACY_FIELD_HASHES": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "tagged",
      "configurePreset": "tagged",
      "configuration": "Release"
    },
    {
      "name": "legacy",
      "configurePreset": "legacy",
      "configuration": "Release"
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "configuration": "Debug"
    },
    {
      "name": "sanitizers-int",
      "configurePreset": "sanitizers-int",
      "configuration": "Debug"
    },
    {
      "name": "trapv-i686",
      "configurePreset": "trapv-i686",
      "configuration": "Debug"
    },
    {
      "name": "bitcoin-i686-debug",
      "configurePreset": "bitcoin-i686-debug",
      "configuration": "Debug"
    },
    {
      "name": "valgrind",
      "configurePreset": "valgrind",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "cbmc",
      "configurePreset": "cbmc",
      "configuration": "Debug",
      "targets": [
        "purify_cbmc"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tagged",
      "configurePreset": "tagged",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.property_tests|purify.reference_circuit"
        }
      }
    },
    {
      "name": "legacy",
      "configurePreset": "legacy",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.reference_circuit"
        }
      }
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.property_tests|purify.c_api"
        }
      }
    },
    {
      "name": "sanitizers-int",
      "configurePreset": "sanitizers-int",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.property_tests|purify.c_api"
        }
      }
    },
    {
      "name": "trapv-i686",
      "configurePreset": "trapv-i686",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.c_api"
        }
      }
    },
    {
      "name": "bitcoin-i686-debug",
      "configurePreset": "bitcoin-i686-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify.tests|purify.property_tests|purify.c_api|purify.bench"
        }
      }
    },
    {
      "name": "valgrind",
      "configurePreset": "valgrind",
      "configuration": "RelWithDebInfo",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify\\.valgrind\\..*"
        }
      }
    },
    {
      "name": "cbmc",
      "configurePreset": "cbmc",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "purify\\.cbmc\\..*"
        }
      }
    }
  ]
}
