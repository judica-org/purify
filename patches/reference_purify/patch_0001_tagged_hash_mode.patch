+def tagged_hash_to_int(data, rang, tag, info=b""):
+    """Implement a uniform hash-to-int using repeated tagged hashes."""
+    bits = rang.bit_length()
+    bytes_needed = (bits + 7) // 8
+    mask = 2 ** bits - 1
+    for attempt in range(256):
+        derived = b""
+        block = 0
+        while len(derived) < bytes_needed:
+            derived += tagged_hash(
+                tag,
+                data
+                + info
+                + attempt.to_bytes(8, byteorder='big')
+                + block.to_bytes(8, byteorder='big'),
+            )
+            block += 1
+        v = int.from_bytes(derived[:bytes_needed], 'big') & mask
+        if v < rang:
+            return v
